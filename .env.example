# ARTEMIS · Variables de entorno (ejemplo)
# Copiar a .env y ajustar si hace falta.

# Conexión a Postgres local (docker-compose.yml)
DATABASE_URL="postgresql://artemis:artemis_dev@localhost:5432/artemis_dev"

# Capa de datos que usa la app:
#   prisma -> Postgres real (Sprint 2+)
#   memory -> arrays en memoria (demo / tests sin DB)
DATA_LAYER="prisma"
